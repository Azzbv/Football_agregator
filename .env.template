# ============================================================================
# Football Data Platform — environment configuration.
# Copy to `.env` and adjust. NO secrets/hosts are baked into source; everything
# the app needs at runtime is here.
# ============================================================================

# --- Profile & logging ------------------------------------------------------
# local | prod  (prod => JSON logs)
APP_PROFILE=local
LOG_LEVEL=INFO

# --- Server -----------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000

# --- UI (NiceGUI, mounted on the same FastAPI app) --------------------------
# The UI talks to the API over loopback within the same process; repoint only if
# running the UI against a remote API.
UI_API_BASE_URL=http://127.0.0.1:8000
# NiceGUI per-client session signing secret (dev default; set a real value in
# prod). Not a credential for any external system.
UI_STORAGE_SECRET=change-me-in-prod

# --- MongoDB (fully env-driven; no host/port assembled in code) -------------
# DEFAULT: the host MongoDB already running at :27171, reached from inside the
# container via host.docker.internal (Mac/Windows; Linux via the compose
# extra_hosts gateway mapping).
MONGODB_URI=mongodb://host.docker.internal:27171/?directConnection=true
MONGODB_DATABASE=football
#
# ALTERNATIVE — self-contained compose Mongo (after uncommenting the `mongo`
# service in docker-compose.yml):
# MONGODB_URI=mongodb://mongo:27017/?directConnection=true
#
# ALTERNATIVE — running the app on the host (not in Docker):
# MONGODB_URI=mongodb://localhost:27171/?directConnection=true

# --- Ingestion master switch ------------------------------------------------
INGESTION_ENABLED=true

# Optional season scoping for adapters that honour it.
# SEASON_START=2023-08-01
# SEASON_END=2024-06-30

# --- Per-source enable flags & base URLs ------------------------------------
# StatsBomb (public JSON repo; file fetch, no HTML).
SOURCE_STATSBOMB_ENABLED=true
SOURCE_STATSBOMB_BASE_URL=https://raw.githubusercontent.com/statsbomb/open-data/master/data

# openfootball (public JSON repos; file fetch, no HTML).
SOURCE_OPENFOOTBALL_ENABLED=true
SOURCE_OPENFOOTBALL_BASE_URL=https://raw.githubusercontent.com/openfootball

# FBref (real HTML; rate-limited). OFF by default — opt in deliberately.
# Hard policy cap: <=10 requests/minute, >=6s spacing. Do not raise these.
SOURCE_FBREF_ENABLED=false
SOURCE_FBREF_BASE_URL=https://fbref.com
SOURCE_FBREF_MAX_REQUESTS_PER_MINUTE=10
SOURCE_FBREF_MIN_REQUEST_SPACING_SECONDS=6.0

# Understat (JSON embedded in <script> tags; politely throttled). OFF by default.
SOURCE_UNDERSTAT_ENABLED=false
SOURCE_UNDERSTAT_BASE_URL=https://understat.com
SOURCE_UNDERSTAT_MAX_REQUESTS_PER_MINUTE=20
